# Backend environment variables
# Copy to .env and fill in your values

# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/thyrotrack"

# Auth
# Minimum 32 caractères en production, sinon le serveur refuse de démarrer.
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="30d"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# URL publique canonique du frontend (utilisée dans les liens envoyés par email)
APP_URL="http://localhost:5173"

# Resend (email de confirmation d'inscription)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="ThyroTrack <noreply@votredomaine.com>"
